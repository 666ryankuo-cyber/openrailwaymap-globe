<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Global Railway - Professional GIS Monitor</title>
  <script src="https://cesium.com/downloads/cesiumjs/releases/1.105/Build/Cesium/Cesium.js"></script>
  <link href="https://cesium.com/downloads/cesiumjs/releases/1.105/Build/Cesium/Widgets/widgets.css" rel="stylesheet">
  <style>
    html, body, #cesiumContainer { width: 100%; height: 100%; margin: 0; padding: 0; overflow: hidden; background-color: #000; }
    .glass-panel {
      background: rgba(20, 20, 20, 0.85); 
      color: #fff; border: 1px solid rgba(255,255,255,0.1); 
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "SF Mono", monospace;
      -webkit-backdrop-filter: blur(15px); backdrop-filter: blur(15px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.8); 
      box-sizing: border-box; 
    }
    #tokenOverlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; z-index: 9999; background: #000; }
    #loginBox { padding: 40px; border-radius: 12px; width: 400px; text-align: center; border: 1px solid #333; }
    #tokenInput { width: 100%; padding: 12px; margin: 20px 0; border-radius: 6px; border: 1px solid #444; background: #111; color: #fff; text-align: center; box-sizing: border-box; }
    #startBtn { background: #5dade2; color: #fff; border: none; padding: 12px 24px; border-radius: 4px; cursor: pointer; width: 100%; font-weight: bold; }
    :root { --sidebar-width: 260px; }
    .hud-hidden #menu, .hud-hidden #infoBar, .hud-hidden #inspectPanel { transform: translateX(-400px) !important; opacity: 0; }
    #menu { position: absolute; top: 20px; left: 20px; padding: 20px; border-radius: 12px; width: var(--sidebar-width); z-index: 1000; transition: 0.5s; overflow-y: auto; max-height: 85vh; }
    #searchInput { width: 100%; padding: 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.4); color: #fff; outline: none; margin-bottom: 10px; font-size: 12px; box-sizing: border-box; }
    #infoBar { position: absolute; bottom: 40px; left: 20px; padding: 15px; border-radius: 12px; width: var(--sidebar-width); font-size: 11px; z-index: 1000; transition: 0.5s; display: flex; flex-direction: column; }
    #inspectPanel { 
      position: absolute; bottom: 40px; left: 300px; padding: 20px; border-radius: 12px; 
      width: 300px; font-size: 11px; z-index: 999; transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      transform: translateX(-50px); opacity: 0; pointer-events: none;
    }
    #inspectPanel.active { transform: translateX(0); opacity: 1; pointer-events: auto; }
    .inspect-close { position: absolute; top: 10px; right: 10px; cursor: pointer; color: #5dade2; font-size: 18px; font-weight: bold; }
    .inspect-title { color: #5dade2; font-weight: bold; margin-bottom: 10px; border-bottom: 1px solid rgba(93,173,226,0.3); padding-bottom: 5px; }
    .inspect-data { margin-bottom: 8px; }
    .inspect-label { color: #888; font-size: 9px; display: block; text-transform: uppercase; }
    .label { font-size: 10px; margin-top: 12px; margin-bottom: 5px; color: #5dade2; font-weight: 700; text-transform: uppercase; border-bottom: 1px solid rgba(93, 173, 226, 0.3); }
    .sat-header { display: flex; justify-content: space-between; align-items: center; }
    .sat-val { color: #5dade2; font-size: 10px; }
    input[type="range"] { -webkit-appearance: none; width: 100%; background: #333; height: 4px; border-radius: 2px; margin: 10px 0; outline: none; }
    input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 14px; height: 14px; background: #5dade2; border-radius: 50%; cursor: pointer; }
    select { background: #000; color: #fff; border: 1px solid #444; width: 100%; padding: 6px; border-radius: 4px; margin-bottom: 8px; font-size: 12px; }
    .switch-container { display: flex; align-items: center; justify-content: space-between; margin: 8px 0; font-size: 11px; }
    .switch { position: relative; width: 34px; height: 18px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: #333; transition: .4s; border-radius: 20px; }
    .slider:before { position: absolute; content: ""; height: 12px; width: 12px; left: 3px; bottom: 3px; background: #fff; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background: #5dade2; }
    input:checked + .slider:before { transform: translateX(16px); }
    #compassContainer { position: absolute; top: 80px; right: 20px; width: 50px; height: 50px; z-index: 1000; cursor: pointer; transition: transform 0.2s; }
    #hudToggle { position: absolute; bottom: 100px; right: 20px; width: 48px; height: 48px; border-radius: 50%; cursor: pointer; z-index: 1001; display: flex; justify-content: center; align-items: center; font-size: 20px; }
    .info-item { display: flex; justify-content: space-between; margin-bottom: 4px; color: #888; }
    .info-val { color: #fff; font-weight: bold; }
    #scaleBar { height: 2px; border: 1px solid #fff; border-top: none; width: 80px; margin-top: 5px; }
    @keyframes pulse { 0% { opacity: 0.5; } 50% { opacity: 1; } 100% { opacity: 0.5; } }
  </style>
</head>
<body>

  <div id="tokenOverlay">
    <div id="loginBox" class="glass-panel">
      <h3 style="color:#5dade2; letter-spacing: 2px; margin-bottom: 5px;">RAILWAY MONITOR</h3>
      <input type="password" id="tokenInput" placeholder="Paste your token here...">
      <button id="startBtn">INITIALIZE SYSTEM</button>
    </div>
  </div>

  <div id="cesiumContainer"></div>

  <div id="compassContainer" title="Reset North & Top-down">
    <svg viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="45" stroke="#fff" stroke-width="1" fill="none" opacity="0.3"/>
      <path d="M50,15 L60,50 L50,45 L40,50 Z" fill="#f1948a"/>
      <path d="M50,85 L60,50 L50,55 L40,50 Z" fill="#5dade2"/>
    </svg>
  </div>
  
  <div id="hudToggle" class="glass-panel">🛰️</div>
  
  <div id="menu" class="glass-panel">
    <input type="text" id="searchInput" placeholder="Search Location (OSM)...">
    <div class="label">System Control</div>
    <div class="switch-container"><span>Auto-Rotation</span><label class="switch"><input type="checkbox" id="rotateToggle"><span class="slider"></span></label></div>
    <div class="switch-container"><span>Inspector Mode</span><label class="switch"><input type="checkbox" id="inspectToggle"><span class="slider"></span></label></div>
    <div class="label">Visuals</div>
    <div class="switch-container"><span>3D Buildings</span><label class="switch"><input type="checkbox" id="buildingToggle"><span class="slider"></span></label></div>
    <div class="switch-container"><span>3D Terrain</span><label class="switch"><input type="checkbox" id="terrainToggle"><span class="slider"></span></label></div>
    <div class="switch-container"><span>Lighting</span><label class="switch"><input type="checkbox" id="lightToggle"><span class="slider"></span></label></div>
    <div class="label sat-header"><span>Basemap Saturation</span><span id="baseSatVal" class="sat-val">100%</span></div>
    <input type="range" id="baseSatSlider" min="0" max="3" step="0.1" value="1.0">
    <div class="label sat-header"><span>Railway Saturation</span><span id="railSatVal" class="sat-val">100%</span></div>
    <input type="range" id="railSatSlider" min="0" max="3" step="0.1" value="1.0">
    <div class="label">Railway Map</div>
    <select id="railwaySelect">
      <option value="standard">Infrastructure</option>
      <option value="maxspeed">Max speeds</option>
      <option value="signals">Signalling</option>
      <option value="electrification">Electrification</option>
      <option value="gauge">Gauge</option>
    </select>
    <div class="label">Base Map</div>
    <select id="baseSelect">
      <option value="osm">OpenStreetMap</option>
      <option value="dark">ArcGIS Dark Gray</option>
      <option value="arc_std">ArcGIS Street Map</option>
      <option value="arc_sat">ArcGIS Satellite</option>
      <option value="ion_sat">Cesium Ion Aerial</option>
    </select>
  </div>

  <div id="infoBar" class="glass-panel">
    <div class="info-item"><span style="color:#5dade2">SOLAR TIME</span><span id="timeVal" class="info-val">--:--:--</span></div>
    <div class="info-item">TIMEZONE<span id="tzVal" class="info-val">UTC +0</span></div>
    <div class="info-item">LATITUDE<span id="latVal" class="info-val">0.00°</span></div>
    <div class="info-item">LONGITUDE<span id="lonVal" class="info-val">0.00°</span></div>
    <div class="info-item">ALTITUDE<span id="altVal" class="info-val">--</span></div>
    <div style="margin-top:10px;">
      <div id="scaleLabel" style="font-size: 9px; color: #5dade2; font-weight: bold;">-- KM</div>
      <div id="scaleBar"></div>
    </div>
  </div>

  <div id="inspectPanel" class="glass-panel">
    <div class="inspect-close" id="inspectClose">←</div>
    <div class="inspect-title">RAILWAY INSPECTOR</div>
    <div id="inspectContent"></div>
  </div>

  <script>
    const startBtn = document.getElementById('startBtn');
    startBtn.onclick = () => {
      const token = document.getElementById('tokenInput').value.trim();
      if (token) initSystem(token);
    };

    async function initSystem(token) {
      Cesium.Ion.defaultAccessToken = token;
      try {
        const viewer = new Cesium.Viewer('cesiumContainer', {
          baseLayerPicker: false, geocoder: false, homeButton: true, infoBox: false,
          timeline: false, animation: false, baseLayer: false,
          terrainProvider: new Cesium.EllipsoidTerrainProvider()
        });

        let baseLayer = null, railLayer = null, osmBuildings = null;
        let isRotating = false, cachedTerrain = null, activeController = null;

        // --- 3D 建築開關邏輯 ---
        document.getElementById('buildingToggle').onchange = async (e) => {
          if (e.target.checked) {
            if (!osmBuildings) osmBuildings = await Cesium.createOsmBuildingsAsync();
            if (!viewer.scene.primitives.contains(osmBuildings)) viewer.scene.primitives.add(osmBuildings);
          } else {
            if (osmBuildings) viewer.scene.primitives.remove(osmBuildings);
            osmBuildings = null;
          }
        };

        // --- Home 鍵行為修正：原地飛往高空 ---
        viewer.homeButton.viewModel.command.beforeExecute.addEventListener((e) => {
          e.cancel = true;
          const carto = viewer.camera.positionCartographic;
          viewer.camera.flyTo({
            destination: Cesium.Cartesian3.fromDegrees(
              Cesium.Math.toDegrees(carto.longitude), 
              Cesium.Math.toDegrees(carto.latitude), 
              2000000.0 // 飛往該處 2000km 高空
            ),
            orientation: { heading: 0, pitch: Cesium.Math.toRadians(-90), roll: 0 }
          });
        });

        // --- 指向針校正 ---
        document.getElementById('compassContainer').onclick = () => {
          viewer.camera.flyTo({
            destination: viewer.camera.position,
            orientation: { heading: 0.0, pitch: Cesium.Math.toRadians(-90.0), roll: 0.0 }
          });
        };

        // --- 飽和度與底圖 ---
        const bSatS = document.getElementById('baseSatSlider');
        const rSatS = document.getElementById('railSatSlider');
        const updateBaseSat = () => { if (baseLayer) baseLayer.saturation = parseFloat(bSatS.value); };
        const updateRailSat = () => { if (railLayer) railLayer.saturation = parseFloat(rSatS.value); };
        bSatS.oninput = (e) => {
          document.getElementById('baseSatVal').innerText = `${Math.round(e.target.value * 100)}%`;
          updateBaseSat();
        };
        rSatS.oninput = (e) => {
          document.getElementById('railSatVal').innerText = `${Math.round(e.target.value * 100)}%`;
          updateRailSat();
        };

        async function updateBaseMap(type) {
          if (baseLayer) viewer.imageryLayers.remove(baseLayer);
          let p;
          switch(type) {
            case 'osm': p = new Cesium.OpenStreetMapImageryProvider({ url: 'https://a.tile.openstreetmap.org/' }); break;
            case 'dark': p = await Cesium.ArcGisMapServerImageryProvider.fromUrl('https://services.arcgisonline.com/arcgis/rest/services/Canvas/World_Dark_Gray_Base/MapServer'); break;
            case 'arc_std': p = await Cesium.ArcGisMapServerImageryProvider.fromUrl('https://services.arcgisonline.com/arcgis/rest/services/World_Street_Map/MapServer'); break;
            case 'arc_sat': p = await Cesium.ArcGisMapServerImageryProvider.fromUrl('https://services.arcgisonline.com/arcgis/rest/services/World_Imagery/MapServer'); break;
            case 'ion_sat': p = await Cesium.createWorldImageryAsync(); break;
          }
          baseLayer = viewer.imageryLayers.addImageryProvider(p, 0);
          updateBaseSat();
        }

        function loadRailway(style) {
          if (railLayer) viewer.imageryLayers.remove(railLayer);
          railLayer = viewer.imageryLayers.addImageryProvider(new Cesium.UrlTemplateImageryProvider({
            url: `https://{s}.tiles.openrailwaymap.org/${style}/{z}/{x}/{y}.png`,
            subdomains: ['a', 'b', 'c']
          }));
          updateRailSat();
        }

        // --- Inspector Logic ---
        const inspectToggle = document.getElementById('inspectToggle');
        const inspectPanel = document.getElementById('inspectPanel');
        const inspectContent = document.getElementById('inspectContent');
        const handler = new Cesium.ScreenSpaceEventHandler(viewer.scene.canvas);
        handler.setInputAction(async (click) => {
          if (!inspectToggle.checked) return;
          if (activeController) activeController.abort();
          activeController = new AbortController();
          let cartesian = viewer.scene.pickPosition(click.position);
          if (!Cesium.defined(cartesian)) cartesian = viewer.camera.pickEllipsoid(click.position);
          if (cartesian) {
            const carto = Cesium.Cartographic.fromCartesian(cartesian);
            const lat = Cesium.Math.toDegrees(carto.latitude);
            const lon = Cesium.Math.toDegrees(carto.longitude);
            inspectPanel.classList.add('active');
            inspectContent.innerHTML = `<div style="color:#5dade2; animation: pulse 1s infinite;">📡 Fetching...</div>`;
            try {
              const radius = Math.max(100, viewer.camera.positionCartographic.height / 500);
              const query = `[out:json][timeout:15];way(around:${radius},${lat},${lon})[railway];out tags center;`;
              const res = await fetch(`https://overpass-api.de/api/interpreter?data=${encodeURIComponent(query)}`, { signal: activeController.signal });
              const data = await res.json();
              const tags = data?.elements?.[0]?.tags;
              if (!tags) inspectContent.innerHTML = `<div style="color:#888">No railway detected.</div>`;
              else {
                inspectContent.innerHTML = `
                  <div class="inspect-data"><span class="inspect-label">Infrastructure</span>${tags.name || tags.railway || 'Unknown'}</div>
                  <div class="inspect-data"><span class="inspect-label">Usage / Type</span>${tags.usage || 'N/A'} / ${tags.service || 'N/A'}</div>
                  <div class="inspect-data"><span class="inspect-label">Max Speed</span>${tags.maxspeed || 'N/A'} km/h</div>
                  <div class="inspect-data"><span class="inspect-label">Signalling</span>${tags['railway:signal:main'] || 'Manual'}</div>
                  <div class="inspect-data"><span class="inspect-label">Electrification</span>${tags.electrified || 'None'}</div>
                  <div class="inspect-data"><span class="inspect-label">Gauge</span>${tags.gauge || '1435'} mm</div>`;
              }
            } catch (e) { if (e.name !== 'AbortError') inspectContent.innerHTML = "API Error."; }
          }
        }, Cesium.ScreenSpaceEventType.LEFT_CLICK);

        // --- HUD Logic ---
        function updateHUD() {
          const c = viewer.camera.positionCartographic;
          if (!c) return;
          const lat = Cesium.Math.toDegrees(c.latitude);
          const lon = Cesium.Math.toDegrees(c.longitude);
          const utcOffset = Math.round(lon / 15);
          const now = new Date();
          const solarDate = new Date(now.getTime() + (now.getTimezoneOffset() * 60000) + (3600000 * utcOffset));
          document.getElementById('timeVal').innerText = solarDate.toTimeString().split(' ')[0];
          document.getElementById('tzVal').innerText = `UTC ${utcOffset >= 0 ? '+' : ''}${utcOffset}`;
          document.getElementById('latVal').innerText = `${lat.toFixed(4)}°`;
          document.getElementById('lonVal').innerText = `${lon.toFixed(4)}°`;
          document.getElementById('altVal').innerText = `${(c.height/1000).toFixed(1)} km`;
          document.getElementById('compassContainer').style.transform = `rotate(${-Cesium.Math.toDegrees(viewer.camera.heading)}deg)`;
          const leftPos = viewer.camera.pickEllipsoid(new Cesium.Cartesian2(viewer.scene.canvas.clientWidth/2 - 40, viewer.scene.canvas.clientHeight/2));
          const rightPos = viewer.camera.pickEllipsoid(new Cesium.Cartesian2(viewer.scene.canvas.clientWidth/2 + 40, viewer.scene.canvas.clientHeight/2));
          if (leftPos && rightPos) {
            const dist = Cesium.Cartesian3.distance(leftPos, rightPos) / 1000;
            document.getElementById('scaleLabel').innerText = dist > 1 ? `${dist.toFixed(1)} KM` : `${(dist*1000).toFixed(0)} M`;
          }
        }

        viewer.scene.preRender.addEventListener(updateHUD);
        document.getElementById('baseSelect').onchange = (e) => updateBaseMap(e.target.value);
        document.getElementById('railwaySelect').onchange = (e) => loadRailway(e.target.value);
        document.getElementById('rotateToggle').onchange = (e) => isRotating = e.target.checked;
        document.getElementById('hudToggle').onclick = () => document.body.classList.toggle('hud-hidden');
        document.getElementById('inspectClose').onclick = () => { inspectPanel.classList.remove('active'); };
        document.getElementById('lightToggle').onchange = (e) => { viewer.scene.globe.enableLighting = e.target.checked; };
        document.getElementById('terrainToggle').onchange = async (e) => {
           if (e.target.checked) { if(!cachedTerrain) cachedTerrain = await Cesium.createWorldTerrainAsync(); viewer.terrainProvider = cachedTerrain; }
           else viewer.terrainProvider = new Cesium.EllipsoidTerrainProvider();
        };

        viewer.scene.postUpdate.addEventListener(() => { if (isRotating) viewer.camera.rotate(Cesium.Cartesian3.UNIT_Z, 0.001); });
        document.getElementById('tokenOverlay').style.display = 'none';
        await updateBaseMap('osm');
        loadRailway('standard');
        viewer.camera.setView({ destination: Cesium.Cartesian3.fromDegrees(0, 0, 20000000.0), orientation: { heading: 0, pitch: Cesium.Math.toRadians(-90), roll: 0 } });
      } catch (e) { console.error(e); }
    }
  </script>
</body>
</html>
